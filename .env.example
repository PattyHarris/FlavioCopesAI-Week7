# Pantry Chef environment template
# Copy this file to `.env.local` for local development.
# For Render, add these same keys in the Render dashboard environment settings.

# Required now: OpenAI key used by the Express backend for recipe and image generation.
OPENAI_API_KEY=your_openai_api_key_here

# Optional backward-compatible alias.
# The backend accepts either OPENAI_API_KEY or OPEN_AI_API_KEY.
OPEN_AI_API_KEY=

# Optional local server settings.
HOST=127.0.0.1
PORT=8787

# Optional now. Keep only if you later reconnect Stitch assets/export flow.
STITCH_API_KEY=

# Optional now. Add these to persist bookmarks and search history in Supabase.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
